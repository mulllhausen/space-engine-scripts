// here we fly through the rings of the superjupiter A2
// note: unlike goto+track, fly+track centers A2 and we'll hit it
// so we cannot look back at A2 unfortunately

Date    "3000"
StopTime
Hide    Labels

// near dune
GotoLocation	"before dune suns 3"
{
	Ver		991
	Body	"RS 0-1-3-1882-4073-7-1905343-439 2"
	Parent	"RS 0-1-3-1882-4073-7-1905343-439 2-2.1"
	Date	"3000.01.01 00:02:38.97"
	Time	+2AFB13807895D8D046B55241B0
