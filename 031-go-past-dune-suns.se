	Vel		2.3628778e-05
	Stereobase	1
	BindMode	1
	PhotoMode	0
	Exposure	0
}

// this doesn't work - hits A2
//Select "RS 0-1-3-1882-4073-7-1905343-439 A2"
//Track

Fly { Axis(0, 0, 1) SpeedKm 400000000 }
Wait    11.0

Fly { Axis(0, 0, 1) SpeedKm 50000000  }
Wait    4.0

Fly { Axis(0, 0, 1) SpeedKm 30000000  }
Wait    1.0

Fly { Axis(0, 0, 1) SpeedKm 20000000  }
Wait    1.0

// upto the first little planet after the suns
Fly { Axis(0, 0, 1) SpeedKm 10000000  }
Wait    3.0

// just passed the first little planet (screen bottom)
Fly { Axis(0, 0, 1) SpeedKm 5000000   }
Wait    3.0

Fly { Axis(0, 0, 1) SpeedKm 1000000   }
Wait    2.0

Fly { Axis(0, 0, 1) SpeedKm 500000    }
Wait    20.0

StopFly

GotoLocation "end of 031"
{
	Ver		991
	Body	"RS 0-1-3-1882-4073-7-1905343-439 2"
	Parent	"RS 0-1-3-1882-4073-7-1905343-439 2-2.1"
