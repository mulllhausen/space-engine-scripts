// A simple flight from Earth to Mars
// run "addons/scenario-scripts/earth-to-mars.se"

// pick a specific time so the rendered result is repeatable
Date "3000"
StopTime

Select "Earth"
Goto   { Time 5.0 }
Wait   5.0

Orbit  { AngularSpeed 18.0 }   // 18 deg/s x 20s = one full revolution
Wait   20.0
StopOrbit

Select "Mars"
Goto   { Time 10.0 }
Wait   10.0

Turn   { AngularSpeed 11.25 Axis (0, 1, 0) }
Wait   4.0
StopTurn
